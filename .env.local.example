# Supabase
# NOTE: Running supabase/schema.sql also creates a private "resumes" Storage
# bucket with RLS policies — no separate env vars needed for that, it uses
# the same project URL + service role key below.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq AI — platform-level, used for every organization's AI scoring
GROQ_API_KEY=your-groq-api-key

# Resend Email — platform-level, used to send every organization's emails
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=recruiting@yourdomain.com

# Cal.com OAuth App — Telivio's OWN app credentials (NOT a personal API key).
# Every customer organization connects THEIR OWN Cal.com account through
# this OAuth app, so interviews land on their calendar, not Telivio's.
# Create this at https://cal.com/integrate -> "Create an OAuth app and
# allow user to schedule". Register the redirect URI below as your
# CAL_REDIRECT_URI in that app's settings.
CAL_CLIENT_ID=your-cal-oauth-client-id
CAL_CLIENT_SECRET=your-cal-oauth-client-secret
CAL_REDIRECT_URI=http://localhost:3000/api/cal/callback

# Polar.sh — billing/subscriptions. Telivio's platform-level account, NOT
# per-organization. Create 3 Products in your Polar dashboard (Starter $49/mo,
# Growth $99/mo, Agency $199/mo) and paste their Product IDs below.
# Use POLAR_ENVIRONMENT=sandbox while testing — sandbox.polar.sh is a fully
# separate environment from production with its own tokens/products.
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
POLAR_ENVIRONMENT=sandbox
POLAR_PRODUCT_STARTER=prod_xxxxxxxxxxxx
POLAR_PRODUCT_GROWTH=prod_xxxxxxxxxxxx
POLAR_PRODUCT_AGENCY=prod_xxxxxxxxxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
